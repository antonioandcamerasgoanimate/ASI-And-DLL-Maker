<Window x:Class="ASIAndDLLMaker.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:avalonEdit="clr-namespace:ICSharpCode.AvalonEdit;assembly=ICSharpCode.AvalonEdit"
        Title="ASI and DLL Maker - GTA V Script Creator" 
        Height="760" Width="1200"
        WindowStartupLocation="CenterScreen"
        Background="#0A0A0F"
        Foreground="#E2E2E9"
        FontFamily="Segoe UI">
    
    <Window.Resources>
        <!-- Custom Styles -->
        <Style x:Key="SidebarBtn" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="#9EA0A9"/>
            <Setter Property="Padding" Value="15,12"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" BorderThickness="0" CornerRadius="5">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" 
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#1A1A2A"/>
                                <Setter Property="Foreground" Value="#FFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SidebarBtnCpp" TargetType="Button" BasedOn="{StaticResource SidebarBtn}">
            <Style.Triggers>
                <DataTrigger Binding="{Binding SelectedTab, RelativeSource={RelativeSource AncestorType=Window}}" Value="0">
                    <Setter Property="Background" Value="#1A2A3F"/>
                    <Setter Property="Foreground" Value="#00E5FF"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SidebarBtnCs" TargetType="Button" BasedOn="{StaticResource SidebarBtn}">
            <Style.Triggers>
                <DataTrigger Binding="{Binding SelectedTab, RelativeSource={RelativeSource AncestorType=Window}}" Value="1">
                    <Setter Property="Background" Value="#2B1A3F"/>
                    <Setter Property="Foreground" Value="#D500F9"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SidebarBtnSettings" TargetType="Button" BasedOn="{StaticResource SidebarBtn}">
            <Style.Triggers>
                <DataTrigger Binding="{Binding SelectedTab, RelativeSource={RelativeSource AncestorType=Window}}" Value="2">
                    <Setter Property="Background" Value="#1A1A22"/>
                    <Setter Property="Foreground" Value="#FFFFFF"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SidebarBtnAbout" TargetType="Button" BasedOn="{StaticResource SidebarBtn}">
            <Style.Triggers>
                <DataTrigger Binding="{Binding SelectedTab, RelativeSource={RelativeSource AncestorType=Window}}" Value="3">
                    <Setter Property="Background" Value="#1A1A22"/>
                    <Setter Property="Foreground" Value="#FFFFFF"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="HeaderStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="22"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="Margin" Value="0,0,0,15"/>
        </Style>

        <Style x:Key="SubHeaderStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Foreground" Value="#8EA0AF"/>
            <Setter Property="Margin" Value="0,0,0,5"/>
        </Style>

        <!-- Glass Panel Style -->
        <Style x:Key="GlassPanel" TargetType="Border">
            <Setter Property="Background" Value="#10101A"/>
            <Setter Property="BorderBrush" Value="#222235"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="15"/>
            <Setter Property="Margin" Value="0,0,0,15"/>
        </Style>

        <!-- Form Elements -->
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#161622"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="BorderBrush" Value="#2C2C3C"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="CaretBrush" Value="#00E5FF"/>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Background" Value="#161622"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="BorderBrush" Value="#2C2C3C"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,6"/>
        </Style>

        <!-- Build Button Style -->
        <Style x:Key="BuildButtonCpp" TargetType="Button">
            <Setter Property="Background" Value="#00B8D4"/>
            <Setter Property="Foreground" Value="#000000"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="20,10"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="5">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#00E5FF"/>
                                <Setter Property="Effect">
                                    <Setter.Value>
                                        <DropShadowEffect Color="#00E5FF" BlurRadius="12" ShadowDepth="0" Opacity="0.6"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="BuildButtonCs" TargetType="Button" BasedOn="{StaticResource BuildButtonCpp}">
            <Setter Property="Background" Value="#AA00FF"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="5">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#D500F9"/>
                                <Setter Property="Effect">
                                    <Setter.Value>
                                        <DropShadowEffect Color="#D500F9" BlurRadius="12" ShadowDepth="0" Opacity="0.6"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Sidebar Navigation -->
        <Border Grid.Column="0" Background="#0C0C12" BorderBrush="#1C1C28" BorderThickness="0,0,1,0" Padding="15">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- App Logo/Title -->
                <StackPanel Grid.Row="0" Margin="0,10,0,30">
                    <TextBlock Text="ASI &amp; DLL" FontSize="20" FontWeight="Bold" Foreground="#FFFFFF"/>
                    <TextBlock Text="GTA V Script Maker" FontSize="12" Foreground="#888899" Margin="0,3,0,0"/>
                </StackPanel>

                <!-- Navigation Buttons -->
                <StackPanel Grid.Row="1">
                    <Button Style="{StaticResource SidebarBtnCpp}" Click="BtnCpp_Click" Margin="0,0,0,8">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="C++ Mod (ASI/DLL)" FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource SidebarBtnCs}" Click="BtnCs_Click" Margin="0,0,0,8">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="C# Mod (ASI/DLL)" FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource SidebarBtnSettings}" Click="BtnSettings_Click">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Settings" FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>

                <!-- Footer Info -->
                <TextBlock Grid.Row="2" Text="v1.0.0 (VS 2022)" Foreground="#4A4A58" FontSize="11" HorizontalAlignment="Center" Margin="0,10"/>
            </Grid>
        </Border>

        <!-- Content Area -->
        <Grid Grid.Column="1">
            <TabControl x:Name="TabControlMain" BorderThickness="0" Background="Transparent" Padding="0" Margin="25">
                <TabControl.ItemContainerStyle>
                    <Style TargetType="TabItem">
                        <Setter Property="Visibility" Value="Collapsed"/>
                    </Style>
                </TabControl.ItemContainerStyle>

                <!-- TAB 0: C++ MOD CREATOR -->
                <TabItem>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="180"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Style="{StaticResource HeaderStyle}" Text="C++ Mod Maker (ASI &amp; DLL)"/>

                        <!-- C++ Configurations -->
                        <Border Grid.Row="1" Style="{StaticResource GlassPanel}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="200"/>
                                    <ColumnDefinition Width="160"/>
                                </Grid.ColumnDefinitions>

                                <!-- Inputs: Project Name, Output Dir, and Input Files -->
                                <StackPanel Grid.Column="0" Orientation="Vertical" VerticalAlignment="Center">
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                        <StackPanel Margin="0,0,15,0">
                                            <TextBlock Style="{StaticResource SubHeaderStyle}" Text="Project Name"/>
                                            <TextBox x:Name="TxtCppProjectName" Width="130" Text="CustomScript" VerticalAlignment="Center"/>
                                        </StackPanel>

                                        <StackPanel>
                                            <TextBlock Style="{StaticResource SubHeaderStyle}" Text="Output Directory"/>
                                            <StackPanel Orientation="Horizontal">
                                                <TextBox x:Name="TxtCppOutputPath" Width="280" IsReadOnly="True" VerticalAlignment="Center"/>
                                                <Button Content="Browse..." Margin="5,0,0,0" Padding="8,5" Click="BtnBrowseCpp_Click"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </StackPanel>

                                    <StackPanel>
                                        <TextBlock Style="{StaticResource SubHeaderStyle}" Text="Input Script File(s)"/>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBox x:Name="TxtCppInputFiles" Width="345" IsReadOnly="True" Text="None (Using editor content)" VerticalAlignment="Center"/>
                                            <Button Content="Browse..." Margin="5,0,0,0" Padding="8,5" Click="BtnBrowseCppInput_Click"/>
                                        </StackPanel>
                                    </StackPanel>
                                </StackPanel>

                                <!-- Template Selector -->
                                <StackPanel Grid.Column="1" Margin="10,0,15,0" VerticalAlignment="Center">
                                    <TextBlock Style="{StaticResource SubHeaderStyle}" Text="Template"/>
                                    <ComboBox x:Name="ComboCppTemplate" SelectionChanged="ComboCppTemplate_SelectionChanged">
                                        <ComboBoxItem Content="Base Script Loop"/>
                                        <ComboBoxItem Content="Vehicle Spawner"/>
                                    </ComboBox>
                                </StackPanel>

                                <!-- Actions -->
                                <StackPanel Grid.Column="2" VerticalAlignment="Center" Margin="5,0,0,0">
                                    <Button Content="COMPILE TO ASI" Style="{StaticResource BuildButtonCpp}" Click="BtnCompileCppAsi_Click" Margin="0,0,0,6"/>
                                    <Button Content="COMPILE TO DLL" Style="{StaticResource BuildButtonCpp}" Click="BtnCompileCppDll_Click" Margin="0,0,0,6"/>
                                    <Button Content="Export Solution (ASI)" Padding="10,4" Click="BtnExportCppSolutionAsi_Click" Margin="0,0,0,4"/>
                                    <Button Content="Export Solution (DLL)" Padding="10,4" Click="BtnExportCppSolutionDll_Click"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- AvalonEdit C++ Editor -->
                        <Border Grid.Row="2" BorderBrush="#2C2C3C" BorderThickness="1" CornerRadius="4" Margin="0,0,0,15">
                            <avalonEdit:TextEditor Name="EditorCpp"
                                                   FontFamily="Consolas"
                                                   FontSize="13.5"
                                                   Background="#0F0F16"
                                                   Foreground="#F8F8F2"
                                                   ShowLineNumbers="True"/>
                        </Border>

                        <!-- C++ Log Console -->
                        <Grid Grid.Row="3">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,5">
                                <TextBlock Text="Output Log" FontSize="13" FontWeight="SemiBold" Foreground="#8EA0AF"/>
                                <Button Content="Clear" Margin="15,0,0,0" Padding="5,1" Background="Transparent" Foreground="#888899" BorderThickness="0" Click="BtnClearCppLog_Click"/>
                            </StackPanel>
                            <RichTextBox Grid.Row="1" x:Name="ConsoleCppLog" 
                                         Background="#08080C" Foreground="#A2A2B9" 
                                         BorderBrush="#2C2C3C" BorderThickness="1"
                                         IsReadOnly="True" VerticalScrollBarVisibility="Auto">
                                <FlowDocument>
                                    <Paragraph x:Name="ParaCppLog"/>
                                </FlowDocument>
                            </RichTextBox>
                        </Grid>
                    </Grid>
                </TabItem>

                <!-- TAB 1: C# MOD CREATOR -->
                <TabItem>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="180"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Style="{StaticResource HeaderStyle}" Text="C# Mod Maker (ASI &amp; DLL)"/>

                        <!-- C# Configurations -->
                        <Border Grid.Row="1" Style="{StaticResource GlassPanel}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="140"/>
                                    <ColumnDefinition Width="140"/>
                                    <ColumnDefinition Width="160"/>
                                </Grid.ColumnDefinitions>

                                <!-- Inputs: Project Name, Output Dir, and Input Files -->
                                <StackPanel Grid.Column="0" Orientation="Vertical" VerticalAlignment="Center">
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                        <StackPanel Margin="0,0,15,0">
                                            <TextBlock Style="{StaticResource SubHeaderStyle}" Text="Project Name"/>
                                            <TextBox x:Name="TxtCsProjectName" Width="130" Text="CustomScript" VerticalAlignment="Center"/>
                                        </StackPanel>

                                        <StackPanel>
                                            <TextBlock Style="{StaticResource SubHeaderStyle}" Text="Output Directory"/>
                                            <StackPanel Orientation="Horizontal">
                                                <TextBox x:Name="TxtCsOutputPath" Width="260" IsReadOnly="True" VerticalAlignment="Center"/>
                                                <Button Content="Browse..." Margin="5,0,0,0" Padding="8,5" Click="BtnBrowseCs_Click"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </StackPanel>

                                    <StackPanel>
                                        <TextBlock Style="{StaticResource SubHeaderStyle}" Text="Input Script File(s)"/>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBox x:Name="TxtCsInputFiles" Width="325" IsReadOnly="True" Text="None (Using editor content)" VerticalAlignment="Center"/>
                                            <Button Content="Browse..." Margin="5,0,0,0" Padding="8,5" Click="BtnBrowseCsInput_Click"/>
                                        </StackPanel>
                                    </StackPanel>
                                </StackPanel>

                                <!-- SHVDN Version Selector -->
                                <StackPanel Grid.Column="1" Margin="10,0,10,0" VerticalAlignment="Center">
                                    <TextBlock Style="{StaticResource SubHeaderStyle}" Text="SHVDN Version"/>
                                    <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                        <RadioButton x:Name="RadioShvdn3" Content="v3" IsChecked="True" Foreground="#FFFFFF" Margin="0,0,12,0"/>
                                        <RadioButton x:Name="RadioShvdn2" Content="v2" Foreground="#FFFFFF"/>
                                    </StackPanel>
                                </StackPanel>

                                <!-- Template Selector -->
                                <StackPanel Grid.Column="2" Margin="10,0,15,0" VerticalAlignment="Center">
                                    <TextBlock Style="{StaticResource SubHeaderStyle}" Text="Template"/>
                                    <ComboBox x:Name="ComboCsTemplate" SelectionChanged="ComboCsTemplate_SelectionChanged">
                                        <ComboBoxItem Content="Base Script"/>
                                        <ComboBoxItem Content="Vehicle Spawner"/>
                                    </ComboBox>
                                </StackPanel>

                                <!-- Actions -->
                                <StackPanel Grid.Column="3" VerticalAlignment="Center" Margin="5,0,0,0">
                                    <Button Content="COMPILE TO ASI" Style="{StaticResource BuildButtonCs}" Click="BtnCompileCsAsi_Click" Margin="0,0,0,6"/>
                                    <Button Content="COMPILE TO DLL" Style="{StaticResource BuildButtonCs}" Click="BtnCompileCsDll_Click" Margin="0,0,0,6"/>
                                    <Button Content="Export Solution (ASI)" Padding="10,4" Click="BtnExportCsSolutionAsi_Click" Margin="0,0,0,4"/>
                                    <Button Content="Export Solution (DLL)" Padding="10,4" Click="BtnExportCsSolutionDll_Click"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- AvalonEdit C# Editor -->
                        <Border Grid.Row="2" BorderBrush="#2C2C3C" BorderThickness="1" CornerRadius="4" Margin="0,0,0,15">
                            <avalonEdit:TextEditor Name="EditorCs"
                                                   FontFamily="Consolas"
                                                   FontSize="13.5"
                                                   Background="#0F0F16"
                                                   Foreground="#F8F8F2"
                                                   ShowLineNumbers="True"/>
                        </Border>

                        <!-- C# Log Console -->
                        <Grid Grid.Row="3">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,5">
                                <TextBlock Text="Output Log" FontSize="13" FontWeight="SemiBold" Foreground="#8EA0AF"/>
                                <Button Content="Clear" Margin="15,0,0,0" Padding="5,1" Background="Transparent" Foreground="#888899" BorderThickness="0" Click="BtnClearCsLog_Click"/>
                            </StackPanel>
                            <RichTextBox Grid.Row="1" x:Name="ConsoleCsLog" 
                                         Background="#08080C" Foreground="#A2A2B9" 
                                         BorderBrush="#2C2C3C" BorderThickness="1"
                                         IsReadOnly="True" VerticalScrollBarVisibility="Auto">
                                <FlowDocument>
                                    <Paragraph x:Name="ParaCsLog"/>
                                </FlowDocument>
                            </RichTextBox>
                        </Grid>
                    </Grid>
                </TabItem>

                <!-- TAB 2: SETTINGS -->
                <TabItem>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Style="{StaticResource HeaderStyle}" Text="Settings"/>

                        <StackPanel Grid.Row="1" MaxWidth="700" HorizontalAlignment="Left">
                            <!-- Visual Studio Auto-Detection -->
                            <Border Style="{StaticResource GlassPanel}">
                                <StackPanel>
                                    <TextBlock Text="Visual Studio &amp; MSBuild Detection" FontSize="15" FontWeight="SemiBold" Foreground="#FFFFFF" Margin="0,0,0,10"/>
                                    <TextBlock Text="We require MSBuild to compile C++ ASI projects on the fly. It is bundled with Visual Studio 2022 C++ Development tools." Foreground="#8A8A9E" TextWrapping="Wrap" Margin="0,0,0,15"/>
                                    
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <TextBlock Style="{StaticResource SubHeaderStyle}" Text="Auto-Detected MSBuild Path"/>
                                            <TextBox x:Name="TxtMsBuildPath" IsReadOnly="True"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="1" Margin="15,0,0,0" VerticalAlignment="Bottom" Orientation="Horizontal">
                                            <Ellipse x:Name="StatusDot" Width="12" Height="12" Fill="Red" VerticalAlignment="Center"/>
                                            <TextBlock x:Name="TxtStatusLabel" Text="Not Detected" Foreground="Red" FontSize="13" Margin="8,0,0,0" VerticalAlignment="Center" FontWeight="SemiBold"/>
                                        </StackPanel>
                                    </Grid>
                                    <Button Content="Re-Detect MSBuild" Width="150" HorizontalAlignment="Left" Margin="0,15,0,0" Padding="10,6" Click="BtnRedetect_Click"/>
                                </StackPanel>
                            </Border>

                            <!-- Directory Defaults -->
                            <Border Style="{StaticResource GlassPanel}">
                                <StackPanel>
                                    <TextBlock Text="Default Directories" FontSize="15" FontWeight="SemiBold" Foreground="#FFFFFF" Margin="0,0,0,15"/>
                                    
                                    <StackPanel>
                                        <TextBlock Style="{StaticResource SubHeaderStyle}" Text="Default Output Location"/>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBox x:Name="TxtDefaultOutputDir" Width="450" IsReadOnly="True"/>
                                            <Button Content="Browse..." Margin="5,0,0,0" Padding="8,5" Click="BtnBrowseDefaultOut_Click"/>
                                        </StackPanel>
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Grid>
                </TabItem>
            </TabControl>
        </Grid>
    </Grid>
</Window>
